# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lite:lite@postgres:5432/litescheduler

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Stripe (replace with real values before going live) ───────────────────────
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER
STRIPE_PRICE_ID=price_PLACEHOLDER
STRIPE_SUCCESS_URL=http://localhost:5173/?payment=success
STRIPE_CANCEL_URL=http://localhost:5173/?payment=cancelled

# ── Timefold ──────────────────────────────────────────────────────────────────
SOLVER_TIMEOUT_SECONDS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list — add your CloudFront URL when deploying
ALLOWED_ORIGINS=http://localhost:5173,https://YOUR_CLOUDFRONT_DOMAIN.cloudfront.net
